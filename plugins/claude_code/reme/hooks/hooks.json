{
  "description": "On stop, record this Claude Code session into ReMe long-term memory (background, async).",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/auto_memory.py\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
